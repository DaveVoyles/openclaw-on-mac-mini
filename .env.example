# =============================================================================
# OpenClaw Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Bot Core                                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Create a bot at https://discord.com/developers/applications
# Bot → Token → Copy
DISCORD_BOT_TOKEN=

# Your Discord server (guild) ID
# Enable Developer Mode in Discord → right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Comma-separated Discord user IDs allowed to use privileged commands
# Right-click your profile → Copy User ID
ALLOWED_USER_IDS=

# Discord channel ID for autonomous push notifications (morning briefing, alerts)
# Leave blank to disable proactive push; get ID via Developer Mode → right-click channel
ALERT_CHANNEL_ID=

# Health-check HTTP port inside the container
# HEALTH_PORT=8765

# Webhook security — if set, webhooks require Bearer token
WEBHOOK_SECRET=
# Enforce webhook auth (recommended true outside local dev)
WEBHOOK_REQUIRE_AUTH=true

# Dashboard/API action auth token (required for mutating API endpoints)
# Send as: Authorization: Bearer <token> or X-OpenClaw-Token: <token>
# This same token can also be reused by the OpenClaw CLI client on your Macs.
DASHBOARD_API_TOKEN=
# Require auth for API action endpoints (/api/trigger-scan, memory action, schedule delete)
DASHBOARD_API_AUTH_REQUIRED=true

# --- Channel Role Architecture (prevents context bleed between workflows) ---
# Right-click a Discord channel → Copy Channel ID (requires Developer Mode)
# Leave as 0 or unset to disable role routing for that channel.
DISCORD_CHANNEL_RESEARCH_ID=
DISCORD_CHANNEL_ANALYTICS_ID=
DISCORD_CHANNEL_BOOKMARKS_ID=
DISCORD_CHANNEL_REAL_ESTATE_ID=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  LLM / AI                                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- Google Gemini (primary cloud LLM) ---
GOOGLE_API_KEY=
# Primary model (default: gemini-2.5-flash)
# LLM_MODEL=gemini-2.5-flash
# Max output tokens per response
# LLM_MAX_TOKENS=8192
# Sampling temperature (0.0–2.0)
# LLM_TEMPERATURE=0.7

# --- Rate Limits ---
# Requests per minute / per hour to the cloud LLM
# LLM_RPM_LIMIT=60
# LLM_RPH_LIMIT=500

# --- Conversation ---
# Max tool-use rounds per single request
# LLM_MAX_TOOL_ROUNDS=12
# How many past turns to include in context
# LLM_MAX_HISTORY_TURNS=50
# Minutes of inactivity before a conversation expires
# CONVERSATION_TTL_MINUTES=30

# --- Deep Research / Thinking Mode ---
# Model used for /research command (supports extended thinking)
THINKING_MODEL=gemini-2.5-flash
# Thinking token budget for extended reasoning (higher = more thorough, costs more)
THINKING_BUDGET=8000

# --- Local LLM (Ollama / Gemma) — hybrid routing ---
# Ollama runs on the host; host.docker.internal resolves from inside container
OLLAMA_URL=http://host.docker.internal:11434
# Model to use for conversational (non-tool) queries
OLLAMA_MODEL=gemma4:e4b
# Enable/disable local model routing
LOCAL_LLM_ENABLED=true
# Default model routing: auto (smart routing), local (always Gemma), gemini (always cloud)
DEFAULT_MODEL_PREFERENCE=auto
# Auto routing profile for non-tool asks: copilot-first | balanced | gemini-first | cost-saver
ROUTING_PROFILE=copilot-first
# Whether Ollama model supports tool/function calling
# OLLAMA_TOOLS_ENABLED=true

# Embedding model (optional — override ChromaDB's default all-MiniLM-L6-v2)
# Requires the model to be pulled in Ollama first: ollama pull embeddinggemma
# EMBEDDING_MODEL=embeddinggemma

# --- GitHub Copilot Proxy (optional) ---
# Requires copilot-openai-api or copilot-proxy running locally
# See: https://github.com/yuchanns/copilot-openai-api
# COPILOT_PROXY_URL=http://localhost:9191/v1
# COPILOT_PROXY_TOKEN=

# --- Web Search (cascade: Perplexity → Tavily → DuckDuckGo → Bing Lite) ---
# Perplexity AI (primary search provider) — https://www.perplexity.ai
PERPLEXITY_API_KEY=
# Tavily AI Search (secondary, higher quality) — https://tavily.com
TAVILY_API_KEY=
# Firecrawl (search + extract in one call, free tier: 500 pages/month)
# Get key at https://firecrawl.dev
FIRECRAWL_API_KEY=
# Serper (Google SERP API, $5/mo for 2500 queries) — direct tool, not in cascade
# Get key at https://serper.dev
SERPER_API_KEY=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  News & Data APIs (Free Tiers)                                          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# NewsAPI.org (news aggregation: 80K+ sources)
# Free tier: 100 requests/day — https://newsapi.org
NEWSAPI_KEY=

# API-Sports (multi-sport data: NBA, NFL, MLB, NHL, soccer, etc.)
# Free tier: 100 requests/day — https://api-sports.io
APISPORTS_KEY=

# Alpha Vantage (financial data, market news, sentiment analysis)
# Free tier: 25 requests/day — https://www.alphavantage.co
ALPHAVANTAGE_KEY=

# --- Trakt.tv (TV & movie tracking) ---
# Sign up: https://trakt.tv/oauth/applications
# Free tier: unlimited (with OAuth2)
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
# OAuth2 token (generated after user authorization)
TRAKT_ACCESS_TOKEN=
TRAKT_REFRESH_TOKEN=

# --- Health & Fitness APIs ---
# Fitbit API: https://dev.fitbit.com/apps
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_ACCESS_TOKEN=
FITBIT_REFRESH_TOKEN=

# Open Food Facts API (no key required, but optional user-agent)
OPENFOODFACTS_USER_AGENT=OpenClaw/0.6.0

# OpenAI (optional fallback — used for creative writing and code tasks when OPENAI_API_KEY is set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic (optional fallback — used for code review and analysis when ANTHROPIC_API_KEY is set)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Media Stack (*arr, Plex, Downloads)                                    ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- Sonarr (TV) ---
# SONARR_URL=http://192.168.1.93:8989
SONARR_API_KEY=

# --- Radarr (Movies) ---
# RADARR_URL=http://192.168.1.93:7878
RADARR_API_KEY=

# --- Lidarr (Music) ---
# LIDARR_URL=http://192.168.1.93:8686
LIDARR_API_KEY=

# --- Prowlarr (Indexers) ---
# PROWLARR_URL=http://192.168.1.93:9696
PROWLARR_API_KEY=

# --- Download Clients ---
# Download clients — point to wherever they're running (Mac Mini or NAS)
# Both run on NAS via gluetun: qBittorrent on :8080, SABnzbd on :8775
QBIT_URL=http://192.168.1.8:8080
SABNZBD_URL=http://192.168.1.8:8775
SABNZBD_API_KEY=

# --- Plex / Tautulli ---
# TAUTULLI_URL=http://192.168.1.93:8181
TAUTULLI_API_KEY=
# PLEX_PORT=32400

# --- Overseerr (media requests) ---
# OVERSEERR_URL=http://192.168.1.93:5055
OVERSEERR_API_KEY=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Network / Infrastructure                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Host machine running Docker containers
DOCKER_HOST_IP=192.168.1.93
# Full path to the Copilot CLI binary on the host.
# SSH in BatchMode skips .zshrc/.zprofile, so /opt/homebrew/bin may not be in PATH.
# Run `which copilot` on the host to find the correct value.
COPILOT_CLI_PATH=/opt/homebrew/bin/copilot

# --- AdGuard Home ---
# ADGUARD_URL=http://192.168.1.8:3053
ADGUARD_USER=admin
ADGUARD_PASSWORD=your_adguard_password

# --- Synology NAS ---
NAS_HOST=192.168.1.8
# NAS_IP=192.168.1.8
NAS_SSH_PORT=24
NAS_SSH_USER=dave
NAS_BACKUP_PATH=/volume1/docker/openclaw/backups
# SSH key paths (used by docker-compose.yml volume mounts)
# Defaults to ~/.ssh/id_ed25519 and ~/.ssh/known_hosts if not set
# SSH_KEY_PATH=~/.ssh/id_ed25519
# SSH_KNOWN_HOSTS=~/.ssh/known_hosts
# NAS DSM API (for container/package management tools)
# NAS_URL=http://192.168.1.8:19501
# NAS_USER=
# NAS_PASSWORD=
# NAS_VERIFY_SSL=false

# --- MonsterVision port ---
# MONSTERVISION_PORT=8766

# --- Connectivity checks ---
# DNS_TEST_HOST=8.8.8.8
# PING_TEST_HOST=1.1.1.1

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Directories (container paths — match docker-compose.yml volumes)       ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# CONFIG_DIR=/config
# AUDIT_DIR=/audit
# LOG_DIR=/logs
# MEMORY_DIR=/memory

# Obsidian vault path inside the container
VAULT_DIR=/vault

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Feature Flags                                                          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# --- Thread-based Conversations ---
# Auto-create Discord threads after 3+ exchanges in /ask
THREAD_AUTO_CREATE=true
# Minutes before auto-created threads are archived
# THREAD_ARCHIVE_MINUTES=60
# Max messages per thread before a new thread is created
# THREAD_MAX_MESSAGES=50

# --- Reflection / Memory ---
# Enable post-conversation self-reflection
# REFLECTION_ENABLED=true
# Auto-recall relevant memories from vector store
# AUTO_RECALL_ENABLED=true
# Number of top-k memory results to inject as context
# AUTO_RECALL_TOP_K=3

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Budget / Limits                                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Monthly spending cap for Gemini API (USD)
# GEMINI_BUDGET_LIMIT=30.00
# Gemini pricing per million tokens (for cost tracking)
# GEMINI_PRICE_INPUT_PER_M=0.10
# GEMINI_PRICE_OUTPUT_PER_M=0.40
# Path to spending tracker JSON
# SPENDING_FILE=/memory/spending.json

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Email                                                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Gmail (read/search/send via IMAP/SMTP)
# Requires 2FA + App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Outlook (optional)
# OUTLOOK_USER=
# OUTLOOK_APP_PASSWORD=

# Twilio SMS (optional, for one-tap Discord→SMS)
SMS_PROVIDER=twilio
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Set either TWILIO_FROM_NUMBER or TWILIO_MESSAGING_SERVICE_SID
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
# Optional: enable Twilio Verify helper flows
TWILIO_VERIFY_SERVICE_SID=

# AgentMail (managed inbox for bot-to-bot email)
# AGENTMAIL_API_KEY=
# AGENTMAIL_INBOX=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Google OAuth (Calendar, Gmail OAuth — optional)                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  GitHub (for /github commands)                                          ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Personal access token — https://github.com/settings/tokens
# Needs: repo (read-only) scopes for private repos; public repos work unauthenticated
GITHUB_TOKEN=ghp_your_personal_access_token

# Comma-separated list of repos to use as defaults when no repo arg is given
# Format: owner/repo1,owner/repo2
GITHUB_DEFAULT_REPOS=owner/repo1,owner/repo2

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Sentry (error monitoring)                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Create auth token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=
# Your org slug from Sentry URL: sentry.io/organizations/{SENTRY_ORG}/
SENTRY_ORG=
# Self-hosted: SENTRY_URL=http://192.168.1.x:9000
# SENTRY_URL=https://sentry.io

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  External Services                                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Maton API Gateway (managed OAuth proxy to 100+ APIs)
# Sign in at https://maton.ai/settings → copy your API key
MATON_API_KEY=

# Stable Diffusion (image generation)
# SD_URL=http://host.docker.internal:7861
# SD_TIMEOUT=120

# Glances (system performance monitor)
# GLANCES_URL=http://host.docker.internal:61208

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Ntfy (push notifications to phone)                                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Self-hosted: NTFY_URL=http://192.168.1.x:80, or use ntfy.sh free tier
NTFY_URL=https://ntfy.sh
# Your topic name — keep it secret (acts as password for public ntfy.sh)
NTFY_TOPIC=openclaw-alerts
# Optional: Bearer token for self-hosted ntfy with auth
# NTFY_TOKEN=

# Weather (no API key required — uses Open-Meteo)
WEATHER_DEFAULT_LOCATION=Philadelphia, PA

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  System Configuration                                                   ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

TZ=America/New_York

# Health check server port (exposed for Prometheus/Uptime Kuma)
# HEALTH_PORT=8765

# Configuration directory (defaults to ./config if not set)
# CONFIG_DIR=/app/config

# Audit log directory (defaults to ./data/audit if not set)
# AUDIT_DIR=/app/data/audit

# Error journal path (persistent error tracking across restarts)
# ERROR_JOURNAL=/app/data/error_journal.json

# Incidents file (tracks system incidents/alerts)
# INCIDENTS_FILE=/app/data/incidents.json

# Notification preferences JSON path
# NOTIFICATION_PREFS_PATH=/app/data/notification_prefs.json

# Evening digest hour (0–23, default: 21 = 9 PM)
EVENING_DIGEST_HOUR=21

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  LLM Advanced Configuration                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Maximum conversation history turns to retain (default: 20)
# LLM_MAX_HISTORY_TURNS=20

# Maximum tokens per LLM response (default: 8000)
# LLM_MAX_TOKENS=8000

# Session timeout in minutes (default: 60)
# CONVERSATION_TTL_MINUTES=60

# Auto-recall context from memory (default: true)
# AUTO_RECALL_ENABLED=true

# Number of memory entries to recall per query (default: 3)
# AUTO_RECALL_TOP_K=3

# Vector store directory for ChromaDB embeddings
# CHROMA_DIR=/app/data/chroma

# Similarity threshold for memory recall (0.0-1.0, default: 0.7)
# CHROMA_SIMILARITY_THRESHOLD=0.7

# Embedding model for vector search (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Gemini API budget limit in USD per month (triggers alert when exceeded)
# GEMINI_BUDGET_LIMIT=50.00

# Gemini pricing per million tokens (check current rates at ai.google.dev/pricing)
# GEMINI_PRICE_INPUT_PER_M=0.075
# GEMINI_PRICE_OUTPUT_PER_M=0.30

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Copilot Proxy (OpenAI/GPT via local proxy)                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Local Copilot CLI proxy for free GPT-4o access
# COPILOT_PROXY_URL=http://host.docker.internal:9999
# COPILOT_PROXY_TOKEN=your-proxy-token-here

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Anthropic Claude (optional fallback LLM)                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Get API key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4.5

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  AgentMail (programmatic email for AI agents)                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Get API key at https://agentmail.to
# AGENTMAIL_API_KEY=
# AGENTMAIL_INBOX=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Monitoring & Infrastructure                                            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Glances system monitor (CPU, memory, disk stats)
# GLANCES_URL=http://host.docker.internal:61208

# AdGuard Home (DNS filtering/stats)
# ADGUARD_URL=http://192.168.1.x:3000

# DNS health check target (default: 1.1.1.1)
# DNS_TEST_HOST=1.1.1.1

# Google OAuth (for Google Calendar/Workspace APIs)
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=

# SSH user for remote operations (NAS backups, container management)
# HOST_SSH_USER=dave


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  OMDb API (movie/TV info — free tier: 1000 req/day)                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# Get free key at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=
