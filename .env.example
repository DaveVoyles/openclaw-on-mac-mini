# =============================================================================
# OpenClaw Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Discord Bot Configuration (REQUIRED)
# ---------------------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications
# Bot → Token → Copy
DISCORD_BOT_TOKEN=

# Your Discord server (guild) ID
# Enable Developer Mode in Discord → right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Comma-separated Discord user IDs allowed to use privileged commands
# Right-click your profile → Copy User ID
ALLOWED_USER_IDS=

# ---------------------------------------------------------------------------
# LLM API Keys (Phase 3 — leave blank for now)
# ---------------------------------------------------------------------------
# Google Gemini (paid tier)
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Service API Keys (Phase 5 — media, health, Plex)
# ---------------------------------------------------------------------------
# These keys enable /search, /queue, /health, /recent, /report, /analyze
# Extract from docker-stack config files — see README for instructions

# Docker host IP
DOCKER_HOST_IP=192.168.1.93

# *arr services
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=

# Download clients
SABNZBD_API_KEY=

# Plex / Tautulli
TAUTULLI_API_KEY=

# Overseerr
OVERSEERR_API_KEY=

# OpenAI (optional fallback)
# OPENAI_API_KEY=

# Anthropic (optional fallback)
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# System Configuration
# ---------------------------------------------------------------------------
TZ=America/New_York
