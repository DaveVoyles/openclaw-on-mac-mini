# =============================================================================
# OpenClaw Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Discord Bot Configuration (REQUIRED)
# ---------------------------------------------------------------------------
# Create a bot at https://discord.com/developers/applications
# Bot → Token → Copy
DISCORD_BOT_TOKEN=

# Your Discord server (guild) ID
# Enable Developer Mode in Discord → right-click server → Copy Server ID
DISCORD_GUILD_ID=

# Comma-separated Discord user IDs allowed to use privileged commands
# Right-click your profile → Copy User ID
ALLOWED_USER_IDS=

# ---------------------------------------------------------------------------
# LLM API Keys (Phase 3 — leave blank for now)
# ---------------------------------------------------------------------------
# Google Gemini (paid tier)
GOOGLE_API_KEY=

# ---------------------------------------------------------------------------
# Service API Keys (Phase 5 — media, health, Plex)
# ---------------------------------------------------------------------------
# These keys enable /search, /queue, /health, /recent, /report, /analyze
# Extract from docker-stack config files — see README for instructions

# Docker host IP
DOCKER_HOST_IP=192.168.1.93

# *arr services
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=

# Download clients
SABNZBD_API_KEY=

# Plex / Tautulli
TAUTULLI_API_KEY=

# Overseerr
OVERSEERR_API_KEY=

# OpenAI (optional fallback)
# OPENAI_API_KEY=

# Anthropic (optional fallback)
# ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Channel Role Architecture — prevents context bleed between workflows
# ---------------------------------------------------------------------------
# Right-click a Discord channel → Copy Channel ID (requires Developer Mode)
# Leave as 0 or unset to disable role routing for that channel.

# #research channel — triggers research-assistant prompt injection
DISCORD_CHANNEL_RESEARCH_ID=

# #analytics channel — triggers data-analyst prompt injection
DISCORD_CHANNEL_ANALYTICS_ID=

# #bookmarks channel — triggers knowledge-organizer prompt injection
DISCORD_CHANNEL_BOOKMARKS_ID=

# #real-estate channel — triggers real-estate specialist prompt injection
DISCORD_CHANNEL_REAL_ESTATE_ID=

# ---------------------------------------------------------------------------
# Obsidian Vault (Markdown-First Knowledge Base)
# ---------------------------------------------------------------------------
# Docker container path — matches the volume mount in docker-compose.yml.
# Change host-side path in docker-compose.yml volumes section if needed.
VAULT_DIR=/vault

# ---------------------------------------------------------------------------
# Maintenance / NAS Backup (4:00 AM cron)
# ---------------------------------------------------------------------------
NAS_HOST=192.168.1.8
NAS_SSH_PORT=24
NAS_SSH_USER=dave
NAS_BACKUP_PATH=/volume1/docker/openclaw/backups

# ---------------------------------------------------------------------------
# Maton API Gateway (managed OAuth proxy to 100+ APIs)
# ---------------------------------------------------------------------------
# Sign in at https://maton.ai/settings → copy your API key
MATON_API_KEY=

# ---------------------------------------------------------------------------
# Local LLM (Ollama / Gemma) — hybrid routing
# ---------------------------------------------------------------------------
# Ollama runs on the host; host.docker.internal resolves from inside container
OLLAMA_URL=http://host.docker.internal:11434
# Model to use for conversational (non-tool) queries
OLLAMA_MODEL=gemma3:12b
LOCAL_LLM_ENABLED=true
# Default model routing: auto (smart routing), local (always Gemma), gemini (always cloud)
DEFAULT_MODEL_PREFERENCE=auto

# ---------------------------------------------------------------------------
# Deep Research / Thinking Mode (Phase D)
# ---------------------------------------------------------------------------
# Model used for /research command (supports extended thinking)
THINKING_MODEL=gemini-2.5-flash
# Thinking token budget for extended reasoning (higher = more thorough, costs more)
THINKING_BUDGET=8000

# ---------------------------------------------------------------------------
# Proactive Features (Phase C)
# ---------------------------------------------------------------------------
# Discord channel ID for autonomous push notifications (morning briefing, alerts)
# Leave blank to disable proactive push; get ID via Developer Mode → right-click channel
ALERT_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Weather (Phase E — no API key required)
# ---------------------------------------------------------------------------
# Default location for /weather and weather context in morning briefings
WEATHER_DEFAULT_LOCATION=Philadelphia, PA

# ---------------------------------------------------------------------------
# Web Search (Phase 8 + E)
# ---------------------------------------------------------------------------
# Tavily AI Search (premium, higher quality) — https://tavily.com
TAVILY_API_KEY=
# DuckDuckGo and Bing are used as free fallbacks (no key needed)

# ---------------------------------------------------------------------------
# System Configuration
# ---------------------------------------------------------------------------
TZ=America/New_York

# ---------------------------------------------------------------------------
# Webhook Security (optional — if set, webhooks require Bearer token)
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Service Ports (defaults shown)
# ---------------------------------------------------------------------------
# HEALTH_PORT=8765
# OLLAMA_PORT=11434

# ---------------------------------------------------------------------------
# Overseerr (optional)
# ---------------------------------------------------------------------------
# OVERSEERR_URL=http://localhost:5055
# OVERSEERR_API_KEY=
