# =============================================================================
# OpenClaw Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git — it contains secrets.
# =============================================================================

# ── Slack & Core ─────────────────────────────────────────────────────────────
# REQUIRED: Primary Slack bot token (xoxb-...)
SLACK_BOT_TOKEN=
# REQUIRED: Slack app-level token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=
# Slack app ID (A...)
SLACK_APP_ID=
# Enable Slack integration
SLACK_ENABLED=true
# Slack config token used by manifest sync tooling
SLACK_CONFIG_TOKEN=
# Refresh token paired with SLACK_CONFIG_TOKEN
SLACK_CONFIG_REFRESH_TOKEN=
# User token for Slack user-scoped APIs (optional)
SLACK_USER_TOKEN=
# Slack member ID for proactive file alerts and DM notifications
SLACK_NOTIFY_USER_ID=
# Upload endpoint bearer key
OPENCLAW_UPLOAD_KEY=
# Polling interval for /ai-files notifications (seconds)
OPENCLAW_FILE_POLL_INTERVAL=60
# Public base URL for dashboard, callbacks, and install scripts
OPENCLAW_PUBLIC_URL=https://openclaw.davevoyles.synology.me

# ── Hermes / Host Bridge ─────────────────────────────────────────────────────
# Route /copilot through Hermes by default: ssh or hermes
COPILOT_BACKEND=hermes
# Enable the Slack host bridge
OPENCLAW_HOST_BRIDGE_ENABLED=true
# Comma-separated Slack member IDs allowed to use privileged bridge commands
OPENCLAW_HOST_BRIDGE_ALLOWED_USERS=
# Path to Copilot CLI on the host Mac Mini
COPILOT_CLI_PATH=/opt/homebrew/bin/copilot
# SSH key path mounted inside the container for host bridge access
OPENCLAW_HOST_BRIDGE_KEY=/home/openclaw/.ssh/id_ed25519
# Known-hosts path used by the host bridge
OPENCLAW_HOST_BRIDGE_KNOWN_HOSTS=/home/openclaw/.ssh/bridge_known_hosts
# Enable GitHub Copilot tool-routing when available
COPILOT_TOOLS_ENABLED=true
# Local OpenAI-compatible Copilot proxy URL
COPILOT_PROXY_URL=http://host.docker.internal:9191/v1
# Bearer token for the Copilot proxy
COPILOT_PROXY_TOKEN=
# API key expected by the local /v1 OpenAI-compatible endpoint
OPENCLAW_V1_API_KEY=openclaw

# ── Dashboard & API ──────────────────────────────────────────────────────────
# Bearer token for dashboard mutating API calls
DASHBOARD_API_TOKEN=
# Require auth for dashboard mutating API calls
DASHBOARD_API_AUTH_REQUIRED=true
# Dashboard login username
OPENCLAW_DASHBOARD_USERNAME=
# Dashboard login password
OPENCLAW_DASHBOARD_PASSWORD=
# Signs dashboard session cookies. Generate with: openssl rand -base64 48
DASHBOARD_SESSION_SECRET=

# ── Media Services ───────────────────────────────────────────────────────────
# Tautulli: Plex monitoring / now playing
TAUTULLI_URL=http://host.docker.internal:8181
TAUTULLI_API_KEY=
# Sonarr: TV downloader
SONARR_URL=http://host.docker.internal:8989
SONARR_API_KEY=
# Radarr: movie downloader
RADARR_URL=http://host.docker.internal:7878
RADARR_API_KEY=
# Overseerr: media requests
OVERSEERR_URL=http://host.docker.internal:5055
OVERSEERR_API_KEY=
# Lidarr: music downloader
LIDARR_URL=http://host.docker.internal:8686
LIDARR_API_KEY=
# Prowlarr: indexer manager
PROWLARR_API_KEY=
# qBittorrent download client
QBIT_URL=https://qbittorrent.davevoyles.synology.me
QBIT_USER=admin
QBIT_PASSWORD=
# SABnzbd download client
SABNZBD_URL=http://192.168.1.8:8775
SABNZBD_API_KEY=
# OMDb metadata lookups
OMDB_API_KEY=

# ── Notifications & Scheduling ───────────────────────────────────────────────
# ntfy push notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=openclaw-alerts
# Daily morning briefing hour (24h, default 8)
MORNING_BRIEFING_HOUR=8
# Sentry error monitoring
SENTRY_AUTH_TOKEN=
SENTRY_ORG=

# ── Network, Wake-on-LAN & Monitoring ────────────────────────────────────────
# Docker host / Mac Mini IP
DOCKER_HOST_IP=192.168.1.93
# Wake-on-LAN: primary MacBook Pro hardware MAC
WOL_MACBOOK_PRO_MAC=aa:bb:cc:dd:ee:ff
# Wake-on-LAN: secondary MacBook Pro hardware MAC
WOL_MACBOOK_PRO2_MAC=aa:bb:cc:dd:ee:ff
# Wake-on-LAN broadcast address
WOL_BROADCAST_IP=192.168.1.255
# AdGuard Home credentials
ADGUARD_URL=https://adguard.davevoyles.synology.me
ADGUARD_USER=
ADGUARD_PASSWORD=
# Uptime Kuma status page
UPTIME_KUMA_URL=http://host.docker.internal:3001
UPTIME_KUMA_STATUS_SLUG=main
# Public Grafana base URL used by the /grafana Slack command
GRAFANA_URL=https://grafana.davevoyles.synology.me

# ── NAS ──────────────────────────────────────────────────────────────────────
# Synology DSM base URL
NAS_URL=https://192.168.1.8:5001
# Synology username
NAS_USER=
# Synology password or app password
NAS_PASSWORD=
# Public/shareable NAS base URL used for generated links
NAS_SHARE_BASE_URL=https://davevoyles.synology.me:5001
# Set false for self-signed local NAS certificates
NAS_VERIFY_SSL=false

# ── GitHub & Search Providers ────────────────────────────────────────────────
# GitHub personal access token (API + GitHub Models / Copilot routing if enabled)
GITHUB_TOKEN=
# Default repos for GitHub activity cards and commands
GITHUB_DEFAULT_REPOS=owner/repo1,owner/repo2
# Tavily web search
TAVILY_API_KEY=
# Perplexity web search
PERPLEXITY_API_KEY=
# Firecrawl extraction/search
FIRECRAWL_API_KEY=
# Maton API gateway
MATON_API_KEY=
# News and data providers
NEWSAPI_KEY=
APISPORTS_KEY=
ALPHAVANTAGE_KEY=
POLYGON_API_KEY=

# ── LLM & Local AI ───────────────────────────────────────────────────────────
# Container/server timezone
TZ=America/New_York
# Optional Google Gemini key for legacy/fallback paths
GOOGLE_API_KEY=
# Local Ollama endpoint
OLLAMA_URL=http://host.docker.internal:11434
# Local model name
OLLAMA_MODEL=gemma4:e4b
# Enable local LLM routing
LOCAL_LLM_ENABLED=true

# ── Google, Gmail & Dropbox ──────────────────────────────────────────────────
# Google OAuth credentials (Calendar / Gmail integrations)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Gmail IMAP/SMTP credentials
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Dropbox app credentials
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# ── Legacy / Deprecated Discord Keys ─────────────────────────────────────────
# Discord has been removed from OpenClaw. Keep these only if you still need
# local backwards compatibility with older scripts or existing .env files.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
ALLOWED_USER_IDS=
ALERT_CHANNEL_ID=
DISCORD_CHANNEL_RESEARCH_ID=
DISCORD_CHANNEL_ANALYTICS_ID=
DISCORD_CHANNEL_BOOKMARKS_ID=
DISCORD_CHANNEL_REAL_ESTATE_ID=
GRAFANA_API_KEY=
GRAFANA_USER=admin
NAS_HOST=192.168.1.8
NAS_SSH_PORT=24
NAS_SSH_USER=dave

# Open WebUI session signing key; generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBUI_SECRET_KEY=
